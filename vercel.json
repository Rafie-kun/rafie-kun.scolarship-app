{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "dist/**",
        "data/**",
        "public/data/**"
      ]
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/((?!assets/|favicon\\.ico|favicon\\.png|.*\\.js|.*\\.css|.*\\.png|.*\\.jpg|.*\\.svg|.*\\.json).*)", "destination": "/api/index.ts" }
  ]
}
